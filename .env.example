# 数据库
DB_HOST=192.168.1.6
DB_PORT=5432
DB_NAME=success_diary
DB_USER=diary
DB_PASSWORD=请替换为强密码

# JWT 密钥（至少16字符，建议 openssl rand -hex 32 生成）
JWT_SECRET=请替换为随机字符串

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=请替换为Turnstile站点密钥
TURNSTILE_SECRET_KEY=请替换为Turnstile密钥

# Plausible 统计（可选；留空则不加载）
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# 端口（可选）
APP_PORT=3800

# 反向代理层数（Nginx Proxy Manager -> 应用 时使用 1）
TRUST_PROXY=1
